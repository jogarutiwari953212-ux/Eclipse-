###############################################################################
# 4. Safety Filter
###############################################################################
class SafetyFilter:
    def __init__(self):
        print("Loading toxicity classifier...")
        self.toxicity_classifier = pipeline(
            "text-classification",
            model="unitary/toxic-bert",
            tokenizer="unitary/toxic-bert"
        )
        # Simple PII patterns
        self.pii_patterns = [
            r'\b\d{3}-\d{2}-\d{4}\b',  # SSN
            r'\b\d{16}\b',              # credit card
        ]

    def check_input(self, text: str) -> bool:
        """Return True if safe, False if toxic."""
        result = self.toxicity_classifier(text)[0]
        if result['label'] != 'non-toxic' and result['score'] > 0.7:
            return False
        for pattern in self.pii_patterns:
            if re.search(pattern, text):
                return False
        return True

    def check_output(self, text: str) -> bool:
        return self.check_input(text)


###############################################################################
# 5. Orchestrator
###############################################################################
class Orchestrator:
    def __init__(self, llm: LLMInterface, memory: VectorMemory, tools: ToolRegistry, safety: SafetyFilter):
        self.llm = llm
        self.memory = memory
        self.tools = tools
        self.safety = safety
        # In-memory session history (short-term)
        self.sessions = {}  # session_id -> list of messages

    def process_message(self, user_id: str, session_id: str, message: str) -> str:
        # 1. Safety check on input
        if not self.safety.check_input(message):
            return "I'm sorry, but your message contains inappropriate content."

        # 2. Retrieve long-term memories
        memories = self.memory.search_similar(user_id, message, n_results=3)
        memory_context = "\n".join([f"Past: {m['content']}" for m in memories])

        # 3. Get recent short-term history
        session_history = self.sessions.get(session_id, [])
        recent = session_history[-10:]

        # 4. Build prompt with system instructions
        system_prompt = """You are Echo, a helpful AI assistant. You have access to tools. 
If you need to use a tool, respond with a JSON object containing "tool" and "arguments". 
Otherwise, respond normally.

Available tools:
- calculator: {"tool": "calculator", "arguments": {"expression": "math expression"}}
- web_search: {"tool": "web_search", "arguments": {"query": "search query"}}
- current_time: {"tool": "current_time", "arguments": {}}

Remember to be safe and helpful."""

        full_prompt = system_prompt + "\n\n"
        if memory_context:
            full_prompt += f"Relevant memories:\n{memory_context}\n\n"
        for msg in recent:
            full_prompt += f"{msg['role']}: {msg['content']}\n"
        full_prompt += f"user: {message}\nassistant:"

        # 5. Generate response
        response = self.llm.generate(full_prompt, max_tokens=1024, temperature=0.7)

        # 6. Check for tool call
        tool_call = None
        try:
            json_match = re.search(r'\{.*"tool".*\}', response, re.DOTALL)
            if json_match:
                tool_json = json.loads(json_match.group())
                if "tool" in tool_json:
                    tool_call = tool_json
        except:
            pass

        # 7. Execute tool if needed
        if tool_call:
            tool_name = tool_call["tool"]
            args = tool_call.get("arguments", {})
            tool_result = self.tools.execute(tool_name, args)
            full_prompt += f"\n[Tool result: {tool_result}]\nassistant:"
            final_response = self.llm.generate(full_prompt, max_tokens=1024, temperature=0.7)
        else:
            final_response = response

        # 8. Safety check on output
        if not self.safety.check_output(final_response):
            final_response = "I'm sorry, I cannot provide that response."

        # 9. Store in memory
        self.memory.add_message(user_id, session_id, "user", message)
        self.memory.add_message(user_id, session_id, "assistant", final_response)

        # Update session history
        if session_id not in self.sessions:
            self.sessions[session_id] = []
        self.sessions[session_id].append({"role": "user", "content": message})
        self.sessions[session_id].append({"role": "assistant", "content": final_response})

        return final_response


